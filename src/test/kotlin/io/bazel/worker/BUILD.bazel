load("//kotlin:jvm.bzl", "kt_jvm_test")

kt_jvm_test(
    name = "WorkerContextTest",
    srcs = [
        "WorkerContextTest.kt",
    ],
    test_class = "io.bazel.worker.WorkerContextTest",
