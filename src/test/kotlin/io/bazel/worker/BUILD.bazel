        "//src/main/kotlin/io/bazel/worker",
        "@rules_kotlin_maven_dev//:com_google_truth_truth",
    ],
)

kt_jvm_test(
    name = "InvocationWorkerTest",
    srcs = [
        "InvocationWorkerTest.kt",
